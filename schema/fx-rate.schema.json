{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datsun-620/schema/fx-rate.schema.json",
  "title": "FxRate",
  "description": "One day's fixed exchange rates, fetched once per run.",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "base", "rates", "source"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "base": { "type": "string", "description": "Base currency the rates are quoted against." },
    "rates": {
      "type": "object",
      "description": "Map of currency code to rate against base.",
      "additionalProperties": { "type": "number" }
    },
    "source": { "type": "string" }
  }
}
