{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datsun-620/schema/listing.schema.json",
  "title": "Listing",
  "description": "One Datsun 620 vehicle for sale, captured from a source.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source",
    "source_url",
    "title",
    "price_original",
    "currency",
    "drive_side",
    "drive_side_inferred",
    "king_cab_score",
    "first_seen",
    "last_seen",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "description": "Stable unique id for this listing." },
    "source": { "type": "string", "description": "Source key, e.g. ebay, goonet, bringatrailer." },
    "source_url": { "type": "string", "format": "uri" },
    "title": { "type": "string" },
    "price_original": { "type": ["number", "null"] },
    "currency": { "type": ["string", "null"], "description": "ISO 4217 code, e.g. USD, JPY, GBP." },
    "price_gbp": { "type": ["number", "null"] },
    "fx_rate_used": { "type": ["number", "null"] },
    "fx_date": { "type": ["string", "null"], "format": "date" },
    "country": { "type": ["string", "null"] },
    "region": { "type": ["string", "null"] },
    "drive_side": { "type": "string", "enum": ["LHD", "RHD", "unknown"] },
    "drive_side_inferred": { "type": "boolean" },
    "year": { "type": ["integer", "null"] },
    "trim": { "type": ["string", "null"] },
    "mileage": { "type": ["number", "null"] },
    "mileage_unit": { "type": ["string", "null"], "enum": ["mi", "km", null] },
    "condition_notes": { "type": ["string", "null"] },
    "king_cab_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "Likelihood this is a King Cab. 1 is certain." },
    "king_cab_signals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What drove the score, e.g. 'title:King Cab', 'jp:キングキャブ'."
    },
    "photo_urls": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "first_seen": { "type": "string", "format": "date" },
    "last_seen": { "type": "string", "format": "date" },
    "price_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "price_original"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "price_original": { "type": ["number", "null"] },
          "price_gbp": { "type": ["number", "null"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["active", "sold", "withdrawn", "relisted"] },
    "relisted_from": { "type": ["string", "null"], "description": "id of a prior listing this was relisted from." }
  }
}
