{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datsun-620/schema/spec-variant.schema.json",
  "title": "SpecVariant",
  "description": "One Datsun 620 market variant, with a citation attached to each fact.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_url", "source_name"],
      "properties": {
        "value": { "description": "The value as stated by this source (any type)." },
        "source_url": { "type": "string", "format": "uri" },
        "source_name": { "type": "string" }
      }
    },
    "citedField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "citations"],
      "properties": {
        "value": {},
        "citations": { "type": "array", "items": { "$ref": "#/$defs/citation" } }
      }
    }
  },
  "required": ["id", "market", "years", "body_style"],
  "properties": {
    "id": { "type": "string", "description": "Stable id, e.g. us-1977-1979-kingcab." },
    "market": { "type": "string", "enum": ["US", "UK", "Australia", "Japan", "South Africa", "Europe"] },
    "years": { "type": "string", "description": "e.g. '1977 to 1979'." },
    "body_style": { "type": "string", "enum": ["standard cab", "King Cab", "double cab", "chassis cab"] },
    "bed_length": { "type": ["string", "null"], "enum": ["short", "long", null] },
    "engine": { "$ref": "#/$defs/citedField" },
    "transmission": { "$ref": "#/$defs/citedField" },
    "dimensions": { "$ref": "#/$defs/citedField" },
    "weights": { "$ref": "#/$defs/citedField" },
    "wheels_tyres": { "$ref": "#/$defs/citedField" },
    "trim_levels": { "$ref": "#/$defs/citedField" },
    "production_changes": { "$ref": "#/$defs/citedField" }
  }
}
