---
interface Props {
  title: string;
}
const { title } = Astro.props;
// BASE_URL has no trailing slash here; normalise so joins are always "<base>/x/".
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname;
const isActive = (p: string) => path.startsWith(`${base}/${p}`);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <link rel="icon" href={`${base}/icons/icon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/icons/apple-touch-icon.png`} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#3b2b1d" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#221a12" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Datsun 620" />
    <script is:inline define:vars={{ base }}>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register(`${base}/sw.js`, { scope: `${base}/` });
      }
    </script>
  </head>
  <body>
    <header>
      <a class="brand" href={`${base}/`}>Datsun <span class="brand-620">620</span></a>
      <nav>
        <a href={`${base}/specs/`} class:list={{ active: isActive("specs") }}>Specs</a>
        <a href={`${base}/listings/`} class:list={{ active: isActive("listings") || isActive("vehicle") }}>Listings</a>
      </nav>
    </header>
    <div class="stripes" aria-hidden="true"><i></i><i></i><i></i></div>
    <main>
      <slot />
    </main>
    <footer>
      <div class="stripes footer-stripes" aria-hidden="true"><i></i><i></i><i></i></div>
      <p>Datsun 620 Tracker · specs cited, listings refreshed daily</p>
    </footer>
    <style is:global>
      /* ── Design tokens: 1970s Datsun brochure palette ─────────────────
         Cream paper, chocolate ink, Datsun orange, mustard. Dark theme is
         the same language on umber. Mobile-first at 390px. */
      :root {
        --paper: #f7f1e3;
        --surface: #fffdf7;
        --surface-2: #f1e7d2;
        --ink: #33261a;
        --ink-muted: #75634f;
        --line: #e0d3ba;
        --orange: #d2622a;
        --orange-deep: #b04a1a;
        --mustard: #dba83a;
        --mustard-soft: #f3e3bd;
        --brown-bar: #3b2b1d;
        --bar-text: #f7f1e3;
        --ok: #5f7036;
        --ok-soft: #e8ecd4;
        --warn: #a6402d;
        --warn-soft: #f5ddd4;
        --shadow: 0 1px 2px rgba(59, 43, 29, 0.08), 0 4px 12px rgba(59, 43, 29, 0.07);
        --radius: 12px;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #221a12;
          --surface: #2e241a;
          --surface-2: #382c1f;
          --ink: #f2e8d8;
          --ink-muted: #b3a189;
          --line: #4a3b2a;
          --orange: #e0713a;
          --orange-deep: #c65e2b;
          --mustard: #d9a83c;
          --mustard-soft: #4a3a1e;
          --brown-bar: #1a140d;
          --bar-text: #f2e8d8;
          --ok: #a7b96e;
          --ok-soft: #374021;
          --warn: #e08b74;
          --warn-soft: #4d2a20;
          --shadow: 0 1px 2px rgba(0, 0, 0, 0.35), 0 4px 12px rgba(0, 0, 0, 0.3);
        }
      }

      * {
        box-sizing: border-box;
      }
      html {
        background: var(--paper);
      }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        font-size: 1rem;
        line-height: 1.55;
        color: var(--ink);
        background: var(--paper);
      }

      /* Type scale: bold, tight, a little brochure-loud. */
      h1 {
        font-size: 1.9rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 1.2rem 0 0.6rem;
      }
      h2 {
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: var(--ink-muted);
        margin: 2rem 0 0.8rem;
      }
      h3 {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      a {
        color: var(--orange-deep);
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.65rem 1rem;
        background: var(--brown-bar);
      }
      .brand {
        color: var(--bar-text);
        text-decoration: none;
        font-weight: 800;
        font-size: 1.15rem;
        letter-spacing: 0.01em;
        padding: 0.5rem 0;
      }
      .brand-620 {
        color: var(--mustard);
      }
      nav {
        display: flex;
        gap: 0.25rem;
      }
      nav a {
        color: var(--bar-text);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0.55rem 0.8rem;
        border-radius: 999px;
      }
      nav a.active {
        background: var(--orange);
        color: #fff8ee;
      }

      /* Signature triple stripe, straight off the brochure spine. */
      .stripes {
        display: flex;
        height: 6px;
      }
      .stripes i {
        flex: 1;
        display: block;
      }
      .stripes i:nth-child(1) { background: var(--orange); }
      .stripes i:nth-child(2) { background: var(--mustard); }
      .stripes i:nth-child(3) { background: var(--ok); }

      main {
        max-width: 40rem;
        margin: 0 auto;
        padding: 0.5rem 1rem 2rem;
      }

      footer {
        margin-top: 2rem;
      }
      .footer-stripes {
        height: 4px;
      }
      footer p {
        text-align: center;
        color: var(--ink-muted);
        font-size: 0.8rem;
        padding: 0.75rem 1rem 1.5rem;
        margin: 0;
      }

      /* Shared components */
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      .chip {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 0.2rem 0.7rem;
        letter-spacing: 0.02em;
      }
      .chip-orange {
        background: var(--orange);
        color: #fff8ee;
      }
      .chip-mustard {
        background: var(--mustard-soft);
        color: var(--ink);
      }
      .chip-ok {
        background: var(--ok-soft);
        color: var(--ok);
      }
      .chip-warn {
        background: var(--warn-soft);
        color: var(--warn);
      }
    </style>
  </body>
</html>
