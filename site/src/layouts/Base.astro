---
interface Props {
  title: string;
}
const { title } = Astro.props;
// BASE_URL has no trailing slash here; normalise so joins are always "<base>/x/".
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <link rel="icon" href={`${base}/icons/icon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/icons/apple-touch-icon.png`} />
    <meta name="theme-color" content="#21351f" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Datsun 620" />
    <script is:inline define:vars={{ base }}>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register(`${base}/sw.js`, { scope: `${base}/` });
      }
    </script>
  </head>
  <body>
    <header>
      <a href={`${base}/`}><strong>Datsun 620</strong></a>
      <nav>
        <a href={`${base}/specs/`}>Specs</a>
        <a href={`${base}/listings/`}>Listings</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <style is:global>
      /* Mobile-first: designed at 390px, everything single column. */
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 1rem;
        line-height: 1.5;
        color: #1a1a1a;
        background: #fafaf7;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        background: #21351f;
      }
      header a {
        color: #f2f0e6;
        text-decoration: none;
        /* Thumb-sized tap targets */
        padding: 0.5rem 0.5rem;
      }
      nav {
        display: flex;
        gap: 0.25rem;
      }
      main {
        max-width: 40rem;
        margin: 0 auto;
        padding: 1rem;
      }
    </style>
  </body>
</html>
