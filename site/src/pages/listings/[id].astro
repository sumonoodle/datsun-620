---
import Base from "../../layouts/Base.astro";
import { getListings, type Listing } from "../../lib/data.ts";

export function getStaticPaths() {
  return getListings().map((l) => ({ params: { id: l.id }, props: { listing: l } }));
}
const { listing } = Astro.props as { listing: Listing };
const base = import.meta.env.BASE_URL;
const gbp = (n: number | null | undefined) =>
  n == null ? "-" : `£${n.toLocaleString("en-GB", { maximumFractionDigits: 0 })}`;
const history = (listing.price_history ?? []) as { date: string; price_original: number | null; price_gbp: number | null }[];
---

<Base title={`${listing.title} - Datsun 620 Tracker`}>
  <p><a href={`${base}/listings`}>&larr; All listings</a></p>
  <h1>{listing.title}</h1>
  <p>
    <span class="badge">King Cab {Math.round(listing.king_cab_score * 100)}%</span>
    <span class="badge" style="background:#eee;color:#555"> {listing.status}</span>
  </p>

  <table>
    <tbody>
      <tr><th>Price</th><td>{gbp(listing.price_gbp)}{listing.price_original != null && listing.currency ? ` (${listing.price_original.toLocaleString()} ${listing.currency})` : ""}</td></tr>
      <tr><th>Country</th><td>{listing.country ?? "?"}{listing.region ? `, ${listing.region}` : ""}</td></tr>
      <tr><th>Drive side</th><td>{listing.drive_side}{listing.drive_side_inferred ? " (inferred)" : ""}</td></tr>
      <tr><th>Year</th><td>{listing.year ?? "-"}</td></tr>
      <tr><th>Source</th><td><a href={listing.source_url}>{listing.source}</a></td></tr>
      <tr><th>First seen</th><td>{listing.first_seen ?? "-"}</td></tr>
      <tr><th>Last seen</th><td>{listing.last_seen ?? "-"}</td></tr>
      {listing.king_cab_signals && listing.king_cab_signals.length > 0 && (
        <tr><th>King Cab signals</th><td>{listing.king_cab_signals.join(", ")}</td></tr>
      )}
      {listing.relisted_from && <tr><th>Relisted from</th><td>{listing.relisted_from}</td></tr>}
    </tbody>
  </table>

  <h2>Price history</h2>
  {history.length === 0 ? (
    <p>No price history yet.</p>
  ) : (
    <table>
      <thead><tr><th>Date</th><th>Price (original)</th><th>Price (GBP)</th></tr></thead>
      <tbody>
        {history.map((h) => (
          <tr>
            <td>{h.date}</td>
            <td>{h.price_original != null ? `${h.price_original.toLocaleString()} ${listing.currency ?? ""}` : "-"}</td>
            <td>{gbp(h.price_gbp)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Base>
