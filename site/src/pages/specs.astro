---
import { readFileSync } from "node:fs";
import Base from "../layouts/Base.astro";

interface Citation {
  ref: string;
  note?: string;
}
interface Color {
  name: string;
  hex?: string | null;
  code?: string;
}
interface Variant {
  id: string;
  name: string;
  years: { from: number; to: number };
  body?: string;
  engine?: {
    code?: string | null;
    codes?: string[];
    displacement_cc?: number | null;
    power_hp?: number | null;
    power_note?: string;
  };
  dimensions_mm?: Record<string, number | null>;
  weight_kg?: number | null;
  transmission?: string | null;
  notes?: string;
  confidence?: string;
  unresolved?: string[];
  colors?: Color[];
  citations: Citation[];
}
interface Market {
  market: string;
  name: string;
  notes?: string;
  unresolved?: string[];
  variants: Variant[];
}

let markets: Market[] = [];
let updated = "";
try {
  const specs = JSON.parse(readFileSync("../data/specs.json", "utf8"));
  markets = specs.markets ?? [];
  updated = specs.updated ?? "";
} catch {
  /* renders the empty state below */
}

const dimLabels: Record<string, string> = {
  length: "Length",
  width: "Width",
  height: "Height",
  wheelbase: "Wheelbase",
  bed_length: "Bed length",
};

function engineLine(v: Variant): string | null {
  const e = v.engine;
  if (!e || !e.code) return null;
  const parts = [e.code];
  if (e.displacement_cc) parts.push(`${(e.displacement_cc / 1000).toFixed(1)}L`);
  if (e.power_hp) parts.push(`${e.power_hp} hp`);
  return parts.join(", ");
}

function hostname(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}

// Filterable facets, derived from the data.
function bodyType(v: Variant): string {
  // Name + body, parentheticals stripped. "long bed"/"long body" is a bed
  // type; bare "long wheelbase" is NOT (the UK truck is a standard cab on a
  // long chassis).
  const b = `${v.name} ${v.body ?? ""}`.replace(/\(.*?\)/g, "").toLowerCase();
  if (b.includes("king") || b.includes("extended")) return "King Cab";
  if (b.includes("double")) return "Double cab";
  if (b.includes("ute") || b.includes("tray") || b.includes("utility")) return "Ute";
  if (/long[ -]?(bed|body)/.test(b)) return "Long bed";
  return "Standard cab";
}
function engineCodes(v: Variant): string[] {
  // Curated fitment list; falls back to the headline code only (never prose,
  // which mentions engines a variant did NOT have).
  if (v.engine?.codes) return v.engine.codes;
  return v.engine?.code ? [v.engine.code] : [];
}
const allVariants = markets.flatMap((m) => m.variants);
const bodyTypes = [...new Set(allVariants.map(bodyType))].sort();
const allEngines = [...new Set(allVariants.flatMap(engineCodes))].sort();
const allColors = [...new Set(allVariants.flatMap((v) => (v.colors ?? []).map((c) => c.name)))].sort();
const years = [1971, 1972, 1973, 1974, 1975, 1976, 1977, 1978, 1979, 1980];
---

<Base title="Specs — Datsun 620 Tracker">
  <h1>Specs</h1>
  {
    markets.length === 0 ? (
      <p>The specs database has not been generated yet.</p>
    ) : (
      <>
        <p class="intro">
          Every Datsun 620 variant by market, curated once with citations.
          {updated && ` Last updated ${updated}.`}
        </p>
        <form class="filters" id="filters">
          <select class="fchip" name="region" aria-label="Region">
            <option value="">All regions</option>
            {markets.map((m) => (
              <option value={m.market}>{m.name}</option>
            ))}
          </select>
          <select class="fchip" name="body" aria-label="Model type">
            <option value="">All types</option>
            {bodyTypes.map((b) => (
              <option value={b}>{b}</option>
            ))}
          </select>
          <select class="fchip" name="year" aria-label="Available in year">
            <option value="">Any year</option>
            {years.map((y) => (
              <option value={y}>{y}</option>
            ))}
          </select>
          <select class="fchip" name="engine" aria-label="Engine">
            <option value="">All engines</option>
            {allEngines.map((e) => (
              <option value={e}>{e}</option>
            ))}
          </select>
          <select class="fchip" name="color" aria-label="Colour">
            <option value="">All colours</option>
            {allColors.map((c) => (
              <option value={c}>{c}</option>
            ))}
          </select>
        </form>
        <p class="count supporting" id="filter-count" aria-live="polite"></p>
        <p class="compare-link">
          <a class="btn-text" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/compare/`}>Compare two variants side by side →</a>
        </p>
        {markets.map((m) => (
          <section id={m.market} data-market={m.market}>
            <h2>{m.name}</h2>
            {m.notes && <p class="market-notes">{m.notes}</p>}
            {m.variants.map((v) => (
              <article class="card elevated variant" data-market={m.market}
                       data-body={bodyType(v)} data-from={v.years.from} data-to={v.years.to}
                       data-engines={engineCodes(v).join("|")}
                       data-colors={(v.colors ?? []).map((c) => c.name).join("|")}>
                <div class="variant-head">
                  <h3>{v.name}</h3>
                  <p class="years">
                    <span class="chip chip-tonal">{v.years.from}–{v.years.to}</span>
                    {v.body && <span class="body-note">{v.body}</span>}
                  </p>
                </div>
                <dl>
                  {engineLine(v) && (
                    <>
                      <dt>Engine</dt>
                      <dd>
                        {engineLine(v)}
                        {v.engine?.power_note && (
                          <span class="fine"> ({v.engine.power_note})</span>
                        )}
                      </dd>
                    </>
                  )}
                  {v.dimensions_mm &&
                    Object.entries(v.dimensions_mm)
                      .filter(([, val]) => val != null)
                      .map(([k, val]) => (
                        <>
                          <dt>{dimLabels[k] ?? k}</dt>
                          <dd>{val} mm</dd>
                        </>
                      ))}
                  {v.weight_kg != null && (
                    <>
                      <dt>Kerb weight</dt>
                      <dd>{v.weight_kg} kg</dd>
                    </>
                  )}
                  {v.transmission && (
                    <>
                      <dt>Transmission</dt>
                      <dd>{v.transmission}</dd>
                    </>
                  )}
                </dl>
                {v.colors && v.colors.length > 0 && (
                  <div class="colors">
                    <p class="colors-label">Factory colours</p>
                    <ul class="swatches">
                      {v.colors.map((c) => (
                        <li class="swatch-tile">
                          <span
                            class="swatch-block"
                            style={c.hex ? `background:${c.hex}` : ""}
                            data-unknown={c.hex ? undefined : "true"}
                            aria-hidden="true"
                          />
                          <span class="swatch-name">{c.name}</span>
                          {c.code && <span class="swatch-code">{c.code}</span>}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {v.notes && <p class="variant-notes">{v.notes}</p>}
                {v.confidence && (
                  <p class={`chip confidence-${v.confidence}`}>
                    data confidence: {v.confidence}
                  </p>
                )}
                <details>
                  <summary>Sources ({v.citations.length})</summary>
                  <ul>
                    {v.citations.map((c) => (
                      <li>
                        {c.ref.startsWith("http") ? (
                          <a href={c.ref} rel="noopener">
                            {hostname(c.ref)}
                          </a>
                        ) : (
                          c.ref
                        )}
                        {c.note && <span class="fine"> — {c.note}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
                {v.unresolved && v.unresolved.length > 0 && (
                  <details>
                    <summary>Open questions ({v.unresolved.length})</summary>
                    <ul>
                      {v.unresolved.map((u) => (
                        <li>{u}</li>
                      ))}
                    </ul>
                  </details>
                )}
              </article>
            ))}
          </section>
        ))}
        <script>
          const form = document.getElementById("filters") as HTMLFormElement | null;
          const variants = Array.from(document.querySelectorAll("article.variant")) as HTMLElement[];
          const count = document.getElementById("filter-count");

          function loadFromUrl() {
            if (!form) return;
            const params = new URLSearchParams(location.search);
            for (const el of form.querySelectorAll("select")) {
              const input = el as HTMLSelectElement;
              if (params.has(input.name)) input.value = params.get(input.name) ?? "";
            }
          }
          function saveToUrl() {
            if (!form) return;
            const params = new URLSearchParams();
            for (const el of form.querySelectorAll("select")) {
              const input = el as HTMLSelectElement;
              if (input.value) params.set(input.name, input.value);
            }
            const qs = params.toString();
            history.replaceState(null, "", qs ? `?${qs}` : location.pathname);
          }

          function apply() {
            if (!form) return;
            const data = new FormData(form);
            const region = data.get("region") as string;
            const body = data.get("body") as string;
            const year = Number(data.get("year")) || null;
            const engine = data.get("engine") as string;
            const color = data.get("color") as string;
            let shown = 0;
            for (const el of variants) {
              const from = Number(el.dataset.from);
              const to = Number(el.dataset.to);
              const engines = (el.dataset.engines ?? "").split("|");
              const colors = (el.dataset.colors ?? "").split("|");
              const ok =
                (!region || el.dataset.market === region) &&
                (!body || el.dataset.body === body) &&
                (year === null || (from <= year && year <= to)) &&
                (!engine || engines.includes(engine)) &&
                (!color || colors.includes(color));
              el.style.display = ok ? "" : "none";
              if (ok) shown++;
            }
            // A market section disappears entirely when none of its variants match.
            for (const section of document.querySelectorAll("main section[data-market]")) {
              const any = Array.from(section.querySelectorAll("article.variant"))
                .some((v) => (v as HTMLElement).style.display !== "none");
              (section as HTMLElement).style.display = any ? "" : "none";
            }
            if (count) count.textContent = `showing ${shown} of ${variants.length} variants`;
            for (const el of form.querySelectorAll("select")) {
              (el as HTMLElement).classList.toggle("fchip-active", Boolean((el as HTMLSelectElement).value));
            }
            saveToUrl();
          }
          form?.addEventListener("input", apply);
          loadFromUrl();
          apply();
        </script>
      </>
    )
  }
  <style>
    .intro,
    .market-notes {
      color: var(--on-surface-variant);
      font-size: 0.92rem;
    }
    .intro {
      margin-top: 0;
    }
    section {
      margin-top: 1.25rem;
    }
    .variant {
      padding: 1rem;
      margin: 0.9rem 0;
    }
    .variant h3 {
      margin: 0;
    }
    .years {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0.4rem 0 0.9rem;
    }
    .body-note {
      color: var(--on-surface-variant);
      font-size: 0.85rem;
    }
    dl {
      display: grid;
      grid-template-columns: minmax(7rem, auto) 1fr;
      gap: 0.3rem 0.75rem;
      margin: 0;
      font-size: 0.95rem;
    }
    dt {
      color: var(--on-surface-variant);
    }
    dd {
      margin: 0;
    }
    .colors {
      margin-top: 0.9rem;
    }
    .colors-label {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--primary);
      margin: 0 0 0.4rem;
    }
    .swatches {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(6.4rem, 1fr));
      gap: 0.6rem;
    }
    .swatch-tile {
      display: flex;
      flex-direction: column;
    }
    .swatch-block {
      display: block;
      height: 3.4rem;
      border-radius: 12px;
      border: 1px solid var(--outline-variant);
    }
    .swatch-block[data-unknown] {
      background: repeating-linear-gradient(45deg, var(--surface-container), var(--surface-container) 5px, var(--outline-variant) 5px, var(--outline-variant) 10px);
    }
    .swatch-name {
      font-size: 0.8rem;
      font-weight: 500;
      margin-top: 0.35rem;
      line-height: 1.25;
    }
    .swatch-code {
      font-size: 0.72rem;
      color: var(--on-surface-variant);
    }
    .variant-notes {
      font-size: 0.9rem;
      color: var(--on-surface-variant);
    }
    .fine {
      color: var(--on-surface-variant);
      font-size: 0.85em;
    }
    .confidence-high {
      background: var(--tertiary-container);
      color: var(--on-tertiary-container);
    }
    .confidence-medium {
      background: var(--secondary-container);
      color: var(--on-secondary-container);
    }
    .confidence-low {
      background: var(--error-container);
      color: var(--on-error-container);
    }
    details {
      margin-top: 0.75rem;
      font-size: 0.9rem;
    }
    summary {
      cursor: pointer;
      color: var(--primary);
      font-weight: 500;
      padding: 0.45rem 0; /* thumb-sized tap target */
    }
    details ul {
      margin: 0.25rem 0 0;
      padding-left: 1.25rem;
    }
    details li {
      overflow-wrap: anywhere;
      margin: 0.3rem 0;
    }
  </style>
</Base>
