---
import { readFileSync } from "node:fs";
import Base from "../layouts/Base.astro";

interface Citation {
  ref: string;
  note?: string;
}
interface Color {
  name: string;
  hex?: string | null;
  code?: string;
}
interface Variant {
  id: string;
  name: string;
  years: { from: number; to: number };
  body?: string;
  engine?: {
    code?: string | null;
    displacement_cc?: number | null;
    power_hp?: number | null;
    power_note?: string;
  };
  dimensions_mm?: Record<string, number | null>;
  weight_kg?: number | null;
  transmission?: string | null;
  notes?: string;
  confidence?: string;
  unresolved?: string[];
  colors?: Color[];
  citations: Citation[];
}
interface Market {
  market: string;
  name: string;
  notes?: string;
  unresolved?: string[];
  variants: Variant[];
}

let markets: Market[] = [];
let updated = "";
try {
  const specs = JSON.parse(readFileSync("../data/specs.json", "utf8"));
  markets = specs.markets ?? [];
  updated = specs.updated ?? "";
} catch {
  /* renders the empty state below */
}

const dimLabels: Record<string, string> = {
  length: "Length",
  width: "Width",
  height: "Height",
  wheelbase: "Wheelbase",
  bed_length: "Bed length",
};

function engineLine(v: Variant): string | null {
  const e = v.engine;
  if (!e || !e.code) return null;
  const parts = [e.code];
  if (e.displacement_cc) parts.push(`${(e.displacement_cc / 1000).toFixed(1)}L`);
  if (e.power_hp) parts.push(`${e.power_hp} hp`);
  return parts.join(", ");
}

function hostname(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}
---

<Base title="Specs — Datsun 620 Tracker">
  <h1>Specs</h1>
  {
    markets.length === 0 ? (
      <p>The specs database has not been generated yet.</p>
    ) : (
      <>
        <p class="intro">
          Every Datsun 620 variant by market, curated once with citations.
          {updated && ` Last updated ${updated}.`}
        </p>
        <nav class="markets-nav">
          {markets.map((m) => (
            <a href={`#${m.market}`}>{m.name}</a>
          ))}
        </nav>
        {markets.map((m) => (
          <section id={m.market}>
            <h2>{m.name}</h2>
            {m.notes && <p class="market-notes">{m.notes}</p>}
            {m.variants.map((v) => (
              <article class="card variant">
                <div class="variant-head">
                  <h3>{v.name}</h3>
                  <p class="years">
                    <span class="chip chip-orange">{v.years.from}–{v.years.to}</span>
                    {v.body && <span class="body-note">{v.body}</span>}
                  </p>
                </div>
                <dl>
                  {engineLine(v) && (
                    <>
                      <dt>Engine</dt>
                      <dd>
                        {engineLine(v)}
                        {v.engine?.power_note && (
                          <span class="fine"> ({v.engine.power_note})</span>
                        )}
                      </dd>
                    </>
                  )}
                  {v.dimensions_mm &&
                    Object.entries(v.dimensions_mm)
                      .filter(([, val]) => val != null)
                      .map(([k, val]) => (
                        <>
                          <dt>{dimLabels[k] ?? k}</dt>
                          <dd>{val} mm</dd>
                        </>
                      ))}
                  {v.weight_kg != null && (
                    <>
                      <dt>Kerb weight</dt>
                      <dd>{v.weight_kg} kg</dd>
                    </>
                  )}
                  {v.transmission && (
                    <>
                      <dt>Transmission</dt>
                      <dd>{v.transmission}</dd>
                    </>
                  )}
                </dl>
                {v.colors && v.colors.length > 0 && (
                  <div class="colors">
                    <p class="colors-label">Factory colours</p>
                    <ul class="swatches">
                      {v.colors.map((c) => (
                        <li>
                          <span class="swatch" style={c.hex ? `background:${c.hex}` : ""} data-unknown={c.hex ? undefined : "true"} />
                          <span class="swatch-name">{c.name}{c.code && <span class="fine"> ({c.code})</span>}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {v.notes && <p class="variant-notes">{v.notes}</p>}
                {v.confidence && (
                  <p class={`chip confidence-${v.confidence}`}>
                    data confidence: {v.confidence}
                  </p>
                )}
                <details>
                  <summary>Sources ({v.citations.length})</summary>
                  <ul>
                    {v.citations.map((c) => (
                      <li>
                        {c.ref.startsWith("http") ? (
                          <a href={c.ref} rel="noopener">
                            {hostname(c.ref)}
                          </a>
                        ) : (
                          c.ref
                        )}
                        {c.note && <span class="fine"> — {c.note}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
                {v.unresolved && v.unresolved.length > 0 && (
                  <details>
                    <summary>Open questions ({v.unresolved.length})</summary>
                    <ul>
                      {v.unresolved.map((u) => (
                        <li>{u}</li>
                      ))}
                    </ul>
                  </details>
                )}
              </article>
            ))}
          </section>
        ))}
      </>
    )
  }
  <style>
    .intro,
    .market-notes {
      color: var(--ink-muted);
    }
    .intro {
      margin-top: 0;
    }
    .markets-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    .markets-nav a {
      background: var(--mustard-soft);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.5rem 0.9rem;
      text-decoration: none;
      color: var(--ink);
      font-weight: 600;
      font-size: 0.9rem;
    }
    section {
      margin-top: 1.5rem;
    }
    .variant {
      padding: 1rem;
      margin: 1rem 0;
      border-top: 4px solid var(--orange);
    }
    .variant h3 {
      margin: 0;
    }
    .years {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0.4rem 0 0.9rem;
    }
    .body-note {
      color: var(--ink-muted);
      font-size: 0.9rem;
    }
    dl {
      display: grid;
      grid-template-columns: minmax(7rem, auto) 1fr;
      gap: 0.3rem 0.75rem;
      margin: 0;
    }
    dt {
      color: var(--ink-muted);
    }
    dd {
      margin: 0;
    }
    .colors {
      margin-top: 0.9rem;
    }
    .colors-label {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-muted);
      margin: 0 0 0.4rem;
    }
    .swatches {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.9rem;
    }
    .swatches li {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.9rem;
    }
    .swatch {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 1px solid var(--line);
      display: inline-block;
    }
    .swatch[data-unknown] {
      background: repeating-linear-gradient(45deg, var(--surface-2), var(--surface-2) 3px, var(--line) 3px, var(--line) 6px);
    }
    .variant-notes {
      font-size: 0.95rem;
    }
    .fine {
      color: var(--ink-muted);
      font-size: 0.85em;
    }
    .confidence-high {
      background: var(--ok-soft);
      color: var(--ok);
    }
    .confidence-medium {
      background: var(--mustard-soft);
      color: var(--ink);
    }
    .confidence-low {
      background: var(--warn-soft);
      color: var(--warn);
    }
    details {
      margin-top: 0.75rem;
      font-size: 0.9rem;
    }
    summary {
      cursor: pointer;
      color: var(--orange-deep);
      font-weight: 600;
      padding: 0.4rem 0; /* thumb-sized tap target */
    }
    details ul {
      margin: 0.25rem 0 0;
      padding-left: 1.25rem;
    }
    details li {
      overflow-wrap: anywhere;
      margin: 0.3rem 0;
    }
  </style>
</Base>
