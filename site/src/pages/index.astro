---
import Base from "../layouts/Base.astro";
import { getListings, getSpecs } from "../lib/data.ts";
const base = import.meta.env.BASE_URL;
const listings = getListings();
const specs = getSpecs();
---

<Base title="Datsun 620 Tracker">
  <h1>Datsun 620 Tracker</h1>
  <div class="note">
    <strong>v1 complete.</strong> Specs for all six markets; listings sweep six sources daily
    with recall-first scoring, filters, per-vehicle history, relisted detection, and
    notify-on-change. eBay and live email switch on once credentials are added.
  </div>
  <p>
    Two views:
  </p>
  <ul>
    <li><a href={`${base}/specs`}>Specs</a> &mdash; comparative reference of {specs.length} 620 variants, every value cited.</li>
    <li><a href={`${base}/listings`}>Listings</a> &mdash; King Cab listings worldwide, ranked by likelihood ({listings.length} currently active).</li>
  </ul>
</Base>
