---
import Base from "../layouts/Base.astro";
import { getListings, getSpecs } from "../lib/data.ts";
const base = import.meta.env.BASE_URL;
const listings = getListings();
const specs = getSpecs();
---

<Base title="Datsun 620 Tracker">
  <h1>Datsun 620 Tracker</h1>
  <div class="note">
    <strong>M1 scaffolding.</strong> The pipeline is live but the data below is placeholder.
    Real specs arrive in M2 to M3, real listings in M4 to M5.
  </div>
  <p>
    Two views:
  </p>
  <ul>
    <li><a href={`${base}/specs`}>Specs</a> &mdash; comparative reference of every 620 variant ({specs.length} placeholder variant).</li>
    <li><a href={`${base}/listings`}>Listings</a> &mdash; King Cab listings worldwide ({listings.length} placeholder listing).</li>
  </ul>
</Base>
