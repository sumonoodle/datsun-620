---
import Base from "../layouts/Base.astro";
import { getListings, getSpecs } from "../lib/data.ts";
const base = import.meta.env.BASE_URL;
const listings = getListings();
const specs = getSpecs();
---

<Base title="Datsun 620 Tracker">
  <h1>Datsun 620 Tracker</h1>
  <div class="note">
    <strong>M3.</strong> Specs are live for all six markets, sourced and reconciled with
    a conflicts queue. Listings are still placeholder until M4.
  </div>
  <p>
    Two views:
  </p>
  <ul>
    <li><a href={`${base}/specs`}>Specs</a> &mdash; comparative reference of {specs.length} 620 variants, every value cited.</li>
    <li><a href={`${base}/listings`}>Listings</a> &mdash; King Cab listings worldwide ({listings.length} placeholder listing, real feed in M4).</li>
  </ul>
</Base>
