---
import { readFileSync } from "node:fs";
import Base from "../../layouts/Base.astro";

export function getStaticPaths() {
  let listings: any[] = [];
  try {
    listings = JSON.parse(readFileSync("../data/listings.json", "utf8")).listings ?? [];
  } catch {
    /* no data yet: no vehicle pages */
  }
  return listings.map((l) => ({
    // ':' is awkward in URLs; '--' cannot appear in source names or ids.
    params: { slug: l.id.replaceAll(":", "--") },
    props: { listing: l, all: listings },
  }));
}

const { listing: l, all } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const SOURCE_NAMES: Record<string, string> = {
  ebay: "eBay", bringatrailer: "Bring a Trailer", carsandbids: "Cars & Bids",
  hemmings: "Hemmings", goonet: "Goo-net", yahoo_buyee: "Yahoo (Buyee)",
};
const COUNTRY_NAMES: Record<string, string> = {
  US: "USA", GB: "UK", DE: "Germany", AU: "Australia", JP: "Japan",
  ZA: "South Africa", CA: "Canada", NL: "Netherlands", XX: "location unknown",
};

function money(p: any): string {
  if (!p || p.amount == null) return "no price shown";
  const sym: Record<string, string> = { USD: "$", GBP: "£", EUR: "€", JPY: "¥", AUD: "A$", ZAR: "R" };
  const orig = `${sym[p.currency] ?? p.currency + " "}${p.amount.toLocaleString("en-GB")}`;
  if (p.currency === "GBP" || p.gbp == null) return orig;
  return `${orig} · £${Math.round(p.gbp).toLocaleString("en-GB")}`;
}

const prior = l.relist?.possible && l.relist.prior_id
  ? all.find((x: any) => x.id === l.relist.prior_id)
  : null;
const title = l.title_translated ?? l.title;
---

<Base title={`${title} — Datsun 620 Tracker`}>
  <p class="back"><a href={`${base}/listings/`}>← All listings</a></p>
  <h1 class="vehicle-title">{title}</h1>
  {l.title_translated && <p class="original">{l.title}</p>}
  <p class="chips">
    <span class="chip chip-orange">{money(l.price)}</span>
    <span class={`chip status-chip-${l.status}`}>{l.status}</span>
  </p>
  {l.images?.[0] && (
    <img class="hero card" src={l.images[0]} alt={title} width="640" height="420"
         fetchpriority="high" onerror="this.style.display='none'" />
  )}

  <dl class="card facts">
    <dt>Location</dt>
    <dd>{COUNTRY_NAMES[l.country] ?? l.country}{l.region && ` (${l.region})`}</dd>
    <dt>Drive side</dt>
    <dd>{l.drive_side}</dd>
    {l.year && <><dt>Year</dt><dd>{l.year}</dd></>}
    <dt>Source</dt>
    <dd><a href={l.url} rel="noopener">{SOURCE_NAMES[l.source] ?? l.source} →</a></dd>
    <dt>First seen</dt>
    <dd>{l.first_seen}</dd>
    <dt>Last seen</dt>
    <dd>{l.last_seen}</dd>
    <dt>King Cab match</dt>
    <dd>
      {l.king_cab.matched_terms.join(", ") || "none"}
      {l.king_cab.body_style_check !== "unavailable" &&
        ` (body style check: ${l.king_cab.body_style_check})`}
    </dd>
  </dl>

  {prior && (
    <p class="relist-note">
      Possible relist of{" "}
      <a href={`${base}/vehicle/${prior.id.replaceAll(":", "--")}/`}>
        {prior.title_translated ?? prior.title}
      </a>
      . Signals: {(l.relist?.reasons ?? []).join("; ")}. Heuristic only, not certain.
    </p>
  )}

  <h2>History</h2>
  <table class="card">
    <thead><tr><th>Date</th><th>Status</th><th>Price</th></tr></thead>
    <tbody>
      {l.history.map((h: any) => (
        <tr>
          <td>{h.date}</td>
          <td>{h.status}</td>
          <td>{h.price ? money(h.price) : "—"}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {l.description_snippet && <p class="desc">{l.description_snippet}</p>}

  <style>
    .back {
      margin: 1rem 0 0;
    }
    .back a {
      color: var(--ink-muted);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .vehicle-title {
      margin-bottom: 0.2rem;
    }
    .original {
      color: var(--ink-muted);
      font-size: 0.85rem;
      margin-top: 0;
    }
    .chips {
      display: flex;
      gap: 0.4rem;
      margin: 0.6rem 0 1rem;
    }
    .chips .chip {
      font-size: 0.95rem;
      padding: 0.3rem 0.9rem;
    }
    .status-chip-active {
      background: var(--ok-soft);
      color: var(--ok);
    }
    .status-chip-sold {
      background: var(--ok-soft);
      color: var(--ok);
    }
    .status-chip-withdrawn {
      background: var(--warn-soft);
      color: var(--warn);
    }
    .hero {
      width: 100%;
      height: auto;
    }
    .facts {
      display: grid;
      grid-template-columns: minmax(7rem, auto) 1fr;
      gap: 0.4rem 0.75rem;
      padding: 1rem;
      margin: 1rem 0;
    }
    .facts dt {
      color: var(--ink-muted);
    }
    .facts dd {
      margin: 0;
      overflow-wrap: anywhere;
    }
    .relist-note {
      background: var(--mustard-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 0.75rem 1rem;
      font-size: 0.95rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--ink-muted);
    }
    th, td {
      text-align: left;
      padding: 0.6rem 0.85rem;
      border-bottom: 1px solid var(--line);
      font-size: 0.95rem;
    }
    tbody tr:last-child td {
      border-bottom: none;
    }
    .desc {
      color: var(--ink-muted);
    }
  </style>
</Base>
