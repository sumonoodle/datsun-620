---
import { readFileSync } from "node:fs";
import Base from "../layouts/Base.astro";

interface Price {
  amount: number | null;
  currency: string;
  gbp: number | null;
}
interface Listing {
  id: string;
  source: string;
  url: string;
  title: string;
  title_translated?: string | null;
  year?: number | null;
  country: string;
  region?: string | null;
  drive_side: string;
  price: Price;
  images: string[];
  status: string;
  first_seen: string;
  last_seen: string;
  history: { date: string; status: string }[];
  relist?: { possible: boolean; prior_id?: string | null };
}

let listings: Listing[] = [];
let generated = "";
let sourceHealth: { source: string; ok: boolean; note?: string }[] = [];
try {
  const data = JSON.parse(readFileSync("../data/listings.json", "utf8"));
  listings = data.listings ?? [];
  generated = data.generated_at ?? "";
} catch {
  /* empty state below */
}
try {
  sourceHealth = JSON.parse(readFileSync("../data/run-log.json", "utf8")).sources ?? [];
} catch {
  /* optional */
}

const active = listings.filter((l) => l.status === "active");
const ended = listings.filter((l) => l.status !== "active");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const countries = [...new Set(listings.map((l) => l.country))].sort();

const SOURCE_NAMES: Record<string, string> = {
  ebay: "eBay",
  bringatrailer: "Bring a Trailer",
  carsandbids: "Cars & Bids",
  hemmings: "Hemmings",
  goonet: "Goo-net",
  yahoo_buyee: "Yahoo (Buyee)",
};
const COUNTRY_NAMES: Record<string, string> = {
  US: "USA", GB: "UK", DE: "Germany", AU: "Australia", JP: "Japan",
  ZA: "South Africa", CA: "Canada", NL: "Netherlands", XX: "location unknown",
};

function money(p: Price): string {
  if (p.amount == null) return "no price shown";
  const sym: Record<string, string> = { USD: "$", GBP: "£", EUR: "€", JPY: "¥", AUD: "A$", ZAR: "R" };
  const orig = `${sym[p.currency] ?? p.currency + " "}${p.amount.toLocaleString("en-GB")}`;
  if (p.currency === "GBP" || p.gbp == null) return orig;
  return `${orig} · £${Math.round(p.gbp).toLocaleString("en-GB")}`;
}

function vehicleHref(l: Listing): string {
  return `${base}/vehicle/${l.id.replaceAll(":", "--")}/`;
}
---

<Base title="Listings — Datsun 620 Tracker">
  <h1>Listings</h1>
  {
    listings.length === 0 ? (
      <p>No listings collected yet. The daily sweep populates this page.</p>
    ) : (
      <>
        <p class="intro">
          King Cab listings worldwide, refreshed daily.
          {" "}{active.length} active, {ended.length} ended. Updated {generated}.
        </p>
        <form class="filters" id="filters">
          <select name="country" aria-label="Country">
            <option value="">All countries</option>
            {countries.map((c) => (
              <option value={c}>{COUNTRY_NAMES[c] ?? c}</option>
            ))}
          </select>
          <select name="drive" aria-label="Drive side">
            <option value="">LHD + RHD</option>
            <option value="LHD">LHD</option>
            <option value="RHD">RHD</option>
            <option value="unknown">unknown</option>
          </select>
          <select name="yearmin" aria-label="Year from">
            <option value="">Year from</option>
            {[1971, 1972, 1973, 1974, 1975, 1976, 1977, 1978, 1979].map((y) => (
              <option value={y}>{y}</option>
            ))}
          </select>
          <select name="yearmax" aria-label="Year to">
            <option value="">Year to</option>
            {[1971, 1972, 1973, 1974, 1975, 1976, 1977, 1978, 1979].map((y) => (
              <option value={y}>{y}</option>
            ))}
          </select>
          <input type="number" name="pricemax" inputmode="numeric" placeholder="Max price £" aria-label="Maximum price in GBP" />
          <span class="count" id="filter-count"></span>
        </form>
        {active.length > 0 && <h2 class="section">Active</h2>}
        {active.map((l) => (
          <article class="card listing" data-country={l.country} data-drive={l.drive_side}
                   data-year={l.year ?? ""} data-gbp={l.price.gbp ?? ""}>
            {l.images[0] && (
              <a class="photo" href={vehicleHref(l)}>
                <img src={l.images[0]} alt={l.title} loading="lazy" width="640" height="420" onerror="this.parentElement.style.display='none'" />
                <span class="price-tag">{money(l.price)}</span>
              </a>
            )}
            <div class="body">
              <h3><a href={vehicleHref(l)}>{l.title_translated ?? l.title}</a></h3>
              {l.title_translated && <p class="original">{l.title}</p>}
              {!l.images[0] && <p class="price-line">{money(l.price)}</p>}
              <p class="meta">
                {l.year && <span class="chip chip-mustard">{l.year}</span>}
                <span class="chip chip-mustard">{COUNTRY_NAMES[l.country] ?? l.country}</span>
                <span class="chip chip-mustard">{l.drive_side}</span>
                {l.relist?.possible && <span class="chip chip-warn">possible relist</span>}
              </p>
              <p class="source-line">
                <a href={l.url} rel="noopener">View on {SOURCE_NAMES[l.source] ?? l.source} →</a>
              </p>
            </div>
          </article>
        ))}
        {ended.length > 0 && <h2 class="section">Recently ended</h2>}
        {ended.map((l) => (
          <article class="card listing ended" data-country={l.country} data-drive={l.drive_side}
                   data-year={l.year ?? ""} data-gbp={l.price.gbp ?? ""}>
            {l.images[0] && (
              <a class="photo" href={vehicleHref(l)}>
                <img src={l.images[0]} alt={l.title} loading="lazy" width="640" height="420" onerror="this.parentElement.style.display='none'" />
                <span class="price-tag">{money(l.price)}</span>
                <span class={`status-tag status-${l.status}`}>{l.status}</span>
              </a>
            )}
            <div class="body">
              <h3><a href={vehicleHref(l)}>{l.title_translated ?? l.title}</a></h3>
              {!l.images[0] && (
                <p class="price-line">
                  {money(l.price)} <span class={`chip status-chip-${l.status}`}>{l.status}</span>
                </p>
              )}
              <p class="meta">
                {l.year && <span class="chip chip-mustard">{l.year}</span>}
                <span class="chip chip-mustard">{COUNTRY_NAMES[l.country] ?? l.country}</span>
                <span class="chip chip-mustard">{l.drive_side}</span>
              </p>
              <p class="source-line">
                {SOURCE_NAMES[l.source] ?? l.source} · last seen {l.last_seen}
              </p>
            </div>
          </article>
        ))}
        <script>
          const form = document.getElementById("filters") as HTMLFormElement | null;
          const cards = Array.from(document.querySelectorAll("article.listing")) as HTMLElement[];
          const count = document.getElementById("filter-count");
          function apply() {
            if (!form) return;
            const data = new FormData(form);
            const country = data.get("country") as string;
            const drive = data.get("drive") as string;
            const ymin = Number(data.get("yearmin")) || 0;
            const ymax = Number(data.get("yearmax")) || 9999;
            const pmax = Number(data.get("pricemax")) || Infinity;
            const yearBound = Boolean(data.get("yearmin") || data.get("yearmax"));
            const priceBound = Boolean(data.get("pricemax"));
            let shown = 0;
            for (const el of cards) {
              const year = Number(el.dataset.year) || null;
              const gbp = Number(el.dataset.gbp) || null;
              // A listing with an unknown year/price is hidden when that
              // filter is in use: "max £5000" must not surface no-price cards.
              const ok =
                (!country || el.dataset.country === country) &&
                (!drive || el.dataset.drive === drive) &&
                (year === null ? !yearBound : year >= ymin && year <= ymax) &&
                (gbp === null ? !priceBound : gbp <= pmax);
              el.style.display = ok ? "" : "none";
              if (ok) shown++;
            }
            if (count) count.textContent = `showing ${shown} of ${cards.length}`;
            // Hide a section heading when everything under it is filtered out.
            for (const h2 of document.querySelectorAll("main h2.section")) {
              let el = h2.nextElementSibling;
              let any = false;
              while (el && el.tagName !== "H2") {
                if (el.matches("article.listing") && (el as HTMLElement).style.display !== "none") {
                  any = true;
                  break;
                }
                el = el.nextElementSibling;
              }
              (h2 as HTMLElement).style.display = any ? "" : "none";
            }
          }
          form?.addEventListener("input", apply);
          apply();
        </script>
      </>
    )
  }
  {
    sourceHealth.length > 0 && (
      <details class="health">
        <summary>Source health</summary>
        <ul>
          {sourceHealth.map((s) => (
            <li>
              <span class={`dot ${s.ok ? "dot-ok" : "dot-bad"}`} /> {SOURCE_NAMES[s.source] ?? s.source}
              {!s.ok && s.note && <span class="fine"> — {s.note}</span>}
            </li>
          ))}
        </ul>
      </details>
    )
  }
  <style>
    .intro {
      color: var(--ink-muted);
      margin-top: 0;
    }
    .filters {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      background: var(--surface-2);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 0.75rem;
      align-items: center;
    }
    .filters select,
    .filters input {
      font-size: 1rem;
      padding: 0.6rem 0.5rem; /* thumb-sized */
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--ink);
      width: 100%;
    }
    .count {
      color: var(--ink-muted);
      font-size: 0.85rem;
      grid-column: span 2;
      text-align: right;
    }
    .listing {
      margin: 1rem 0;
    }
    .photo {
      position: relative;
      display: block;
    }
    .photo img {
      width: 100%;
      height: auto;
      display: block;
    }
    .price-tag {
      position: absolute;
      left: 0.75rem;
      bottom: 0.75rem;
      background: var(--orange);
      color: #fff8ee;
      font-weight: 800;
      font-size: 1rem;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      box-shadow: var(--shadow);
    }
    .status-tag {
      position: absolute;
      right: 0.75rem;
      top: 0.75rem;
      font-weight: 800;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 0.3rem 0.75rem;
      border-radius: 999px;
      color: #fff8ee;
    }
    .status-sold {
      background: var(--ok);
    }
    .status-withdrawn {
      background: var(--warn);
    }
    .body {
      padding: 0.85rem 1rem 1rem;
    }
    .body h3 {
      margin: 0 0 0.35rem;
    }
    .body h3 a {
      color: var(--ink);
      text-decoration: none;
    }
    .original {
      color: var(--ink-muted);
      font-size: 0.8rem;
      margin: 0 0 0.35rem;
    }
    .price-line {
      font-weight: 800;
      margin: 0.25rem 0;
    }
    .status-chip-sold {
      background: var(--ok-soft);
      color: var(--ok);
    }
    .status-chip-withdrawn {
      background: var(--warn-soft);
      color: var(--warn);
    }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin: 0.5rem 0 0.35rem;
    }
    .source-line {
      margin: 0.4rem 0 0;
      font-size: 0.9rem;
    }
    .source-line,
    .source-line a {
      color: var(--ink-muted);
    }
    .ended {
      opacity: 0.82;
    }
    .health {
      margin-top: 2rem;
      font-size: 0.9rem;
      background: var(--surface-2);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 0.25rem 1rem;
    }
    .health summary {
      cursor: pointer;
      padding: 0.6rem 0;
      font-weight: 600;
      color: var(--ink);
    }
    .health ul {
      list-style: none;
      margin: 0 0 0.75rem;
      padding: 0;
    }
    .health li {
      margin: 0.45rem 0;
    }
    .dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 0.4rem;
    }
    .dot-ok {
      background: var(--ok);
    }
    .dot-bad {
      background: var(--warn);
    }
    .fine {
      color: var(--ink-muted);
    }
  </style>
</Base>
